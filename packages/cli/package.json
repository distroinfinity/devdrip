{
  "name": "@distrotv/cli",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "bin": {
    "distro": "./dist/index.js",
    "dtv": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@distrotv/shared": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
