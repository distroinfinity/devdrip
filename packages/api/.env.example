# ── database ─────────────────────────────────────────────────────────────────
# local postgres (for development + testing)
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5432/devdrip
DATABASE_URL_LOCAL_UNPOOLED=postgresql://postgres:postgres@localhost:5432/devdrip

# neon postgres (production / staging)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.neon.tech/devdrip?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.region.neon.tech/devdrip?sslmode=require

# which db to use: "local" or "neon"
DB_TARGET=local

# ── github oauth ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ── auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-64-char-hex-string
CLIENT_REDIRECT_URL=http://localhost:3001/auth/debug

# ── upstash redis (rate limiting) ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── cors ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
