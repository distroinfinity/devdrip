# env bundle — picks apiUrl / webUrl from packages/shared/src/env-bundle.ts.
# DISTRO_ENV is server-side; NEXT_PUBLIC_DISTRO_ENV is needed for client code.
# both should match. unset → NODE_ENV decides (development → local).
DISTRO_ENV=local
NEXT_PUBLIC_DISTRO_ENV=local

# explicit overrides (rarely needed — bundle handles staging/prod URLs)
# API_URL=
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_SITE_URL=

# server-side only
JWT_SECRET=
