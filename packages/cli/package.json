{
  "name": "@devdrip/cli",
  "version": "0.1.0",
  "description": "Earn or learn while your AI agent codes — opt-in USDC micropayments and tech news during Claude Code idle time.",
  "private": false,
  "type": "module",
  "bin": {
    "devdrip": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "homepage": "https://devdrip.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/distroinfinity/devdrip.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/distroinfinity/devdrip/issues"
  },
  "keywords": [
    "claude-code",
    "ai",
    "usdc",
    "micropayments",
    "world-chain",
    "developer-tools",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@devdrip/shared": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
