{
  "name": "@distrotv/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --passWithNoTests \"src/**/*.integration.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "worker:dev": "tsx watch src/worker.ts",
    "worker:start": "node dist/worker.js",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@distrotv/shared": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.7.3",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "node-cron": "^4.2.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "postgres": "^3.4.9",
    "resend": "^6.9.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
