# repo-root .env.example
#
# copy to .env (gitignored) and fill in real values. docker compose reads
# the repo-root .env automatically when run from this directory. this file
# documents the variables compose expects — no real secrets live here.
#
# `bash ~/.superset/worktrees/devdrip/setup-worktree.sh --db-up` will
# bootstrap .env from this file if missing.

# ── local postgres (docker compose) ─────────────────────────────────────────
# credentials for the dev-only postgres container on 127.0.0.1:5432.
# pick anything; they must match DATABASE_URL_LOCAL in packages/api/.env.
POSTGRES_USER=change-me
POSTGRES_PASSWORD=change-me
POSTGRES_DB=change-me

# optional host port override (default 5432)
# POSTGRES_PORT=5432
