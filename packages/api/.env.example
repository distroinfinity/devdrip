# ── database ─────────────────────────────────────────────────────────────────
# local postgres via docker compose (default for development)
DB_TARGET=local
DATABASE_URL_LOCAL=postgres://devdrip:devdrip@localhost:5432/devdrip_dev
DATABASE_URL_LOCAL_UNPOOLED=postgres://devdrip:devdrip@localhost:5432/devdrip_dev

# neon postgres (deployed environments: staging / production)
# to deliberately test against neon locally:
#   1. uncomment these two lines and fill in real values
#   2. set DB_TARGET=neon
#   3. run the api with DEVDRIP_ALLOW_NEON_IN_DEV=1 (the guard in env.ts refuses otherwise)
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.neon.tech/devdrip?sslmode=require
# DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.region.neon.tech/devdrip?sslmode=require

# ── github oauth ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ── auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-64-char-hex-string
# where the api bounces browsers to after github oauth. dashboard lives at
# /dashboard on the landing host (single next app).
CLIENT_REDIRECT_URL=http://localhost:3000/auth/callback

# ── upstash redis (rate limiting) ────────────────────────────────────────────
# leave these unset in dev — redis.ts falls back to an in-memory TestRedis
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── cors ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── admin ────────────────────────────────────────────────────────────────────
ADMIN_SECRET=replace-with-random-hex-string

# M2 will add: MAGIC_LINK_FROM, RESEND_API_KEY, MAGIC_LINK_BASE_URL
# M3 may add: NEWS_FETCH_INTERVAL_MS
# M4 will add: FINNHUB_API_KEY, COINGECKO_API_KEY, TICKER_FETCH_INTERVAL_MS
# M7 will add: ADMIN_EMAILS, POSTHOG_API_KEY, SLACK_WEBHOOK_URL
